-- Block / Bypass Adonis Anti-Cheat
local g = getrawmetatable or getmetatable
local setreadonly = setreadonly or make_writeable

if g then
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- ดักจับการส่งข้อมูลตรวจจับกลับไปยัง Server ของ Adonis
        if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
            if tostring(self):find("Adonis") or tostring(self):find("__Adonis") then
                return nil
            end
        end
        return oldNamecall(self, ...)
    end)
end

-- ลบสคริปต์ตรวจจับฝั่ง Client ของ Adonis ออกจาก GC
for _, v in pairs(getgc(true)) do
    if type(v) == "table" and rawget(v, "Detected") and type(rawget(v, "Detected")) == "function" then
        v.Detected = function(...) return task.wait(9e9) end
    end
end
